<fw:AcrylicWindow x:Class="overcloud.Views.LanSendWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fw="clr-namespace:SourceChord.FluentWPF;assembly=FluentWPF"
    Title="LAN 직접 전송"
    Width="420" Height="260"
    AcrylicWindowStyle="None"
    WindowStartupLocation="CenterOwner"
    Background="Transparent">

    <Border Background="{StaticResource AcrylicBG}"
            CornerRadius="6"
            Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 받는 사람 ID -->
            <TextBlock Grid.Row="0" Text="받는 사람 ID" FontSize="13" FontWeight="Bold"
                       Foreground="#444" Margin="0,0,0,4"/>
            <TextBox x:Name="TargetUserIdBox"
                     Grid.Row="1"
                     Style="{StaticResource RoundTextBox}"
                     FontSize="14"
                     Height="36"
                     Margin="0,0,0,12"/>

            <!-- 파일 선택 -->
            <TextBlock Grid.Row="2" Text="전송할 파일" FontSize="13" FontWeight="Bold"
                       Foreground="#444" Margin="0,0,0,4"/>
            <Grid Grid.Row="3" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FilePathBox"
                         Style="{StaticResource RoundTextBox}"
                         FontSize="13" Height="36" IsReadOnly="True"
                         Grid.Column="0" Margin="0,0,8,0"/>
                <Button Content="찾아보기"
                        Style="{StaticResource RoundButton}"
                        Width="80" Height="36"
                        Grid.Column="1"
                        Click="Browse_Click" Cursor="Hand"/>
            </Grid>

            <!-- 진행률 -->
            <ProgressBar x:Name="SendProgress"
                         Grid.Row="4"
                         Height="8" Minimum="0" Maximum="100" Value="0"
                         VerticalAlignment="Center"
                         Margin="0,0,0,8"/>

            <!-- 상태 + 버튼 -->
            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           FontSize="12" Foreground="#666"
                           VerticalAlignment="Center"
                           Text="대기 중"/>
                <Button Content="취소"
                        Style="{StaticResource RoundButton}"
                        Width="70" Height="36"
                        Grid.Column="1" Margin="0,0,8,0"
                        Click="Cancel_Click" Cursor="Hand"/>
                <Button x:Name="SendButton"
                        Content="전송"
                        Style="{StaticResource RoundButton}"
                        Width="80" Height="36"
                        Grid.Column="2"
                        Click="Send_Click" Cursor="Hand"/>
            </Grid>
        </Grid>
    </Border>
</fw:AcrylicWindow>
